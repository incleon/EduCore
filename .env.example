# ============================================================
# Enterprise College Management System — Environment Config
# Copy this file to .env and update values
# ============================================================

APP_NAME=Enterprise College Management System
APP_VERSION=1.0.0
DEBUG=True
DATABASE_URL=mysql+pymysql://cms_user:secure_password@127.0.0.1:3306/cms_db
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_ROOT_USER=root
MYSQL_ROOT_PASSWORD=change_me
MYSQL_DATABASE=cms_db
MYSQL_USER=cms_user
MYSQL_PASSWORD=secure_password
SECRET_KEY=change-this-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
LOG_FILE=logs/cms.log
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=5242880
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100
MAIL_USERNAME=info.educorecms@gmail.com
MAIL_PASSWORD=your-smtp-app-password
MAIL_FROM=info.educorecms@gmail.com
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_STARTTLS=True
MAIL_SSL_TLS=False
MAIL_VALIDATE_CERTS=True
